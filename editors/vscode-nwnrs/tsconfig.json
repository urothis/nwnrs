{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "Node20",
    "moduleResolution": "Node16",
    "noEmit": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "media/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "types/**/*.d.ts"
  ]
}
