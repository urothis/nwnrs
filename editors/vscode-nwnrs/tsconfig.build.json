{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "inlineSources": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": [
    "media/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "media/**/*.ts",
    "test/**/*.ts"
  ]
}
